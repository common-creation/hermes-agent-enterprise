{
  "app": "python3 app.py",
  "watch": {
    "include": [
      "**"
    ],
    "exclude": [
      "README.md",
      "cdk*.json",
      "requirements*.txt",
      "**/__pycache__",
      "**/*.pyc",
      "tests",
      "docs",
      ".git",
      ".venv"
    ]
  },
  "context": {
    "project_name": "hermes-agentcore",
    "@aws-cdk/aws-lambda:recognizeLayerVersion": true,
    "@aws-cdk/core:stackRelativeExports": true,
    "default_model_id": "jp.anthropic.claude-opus-4-8",
    "warmup_model_id": "jp.anthropic.claude-sonnet-4-6",
    "session_idle_timeout": 1800,
    "session_max_lifetime": 28800,
    "workspace_sync_interval_seconds": 300,
    "enable_guardrails": false,
    "enable_token_monitoring": true,
    "daily_token_budget": 100000000,
    "daily_cost_budget_usd": 100,

    "channels": ["slack"],

    "vpc_cidr": "10.0.0.0/16",
    "az_count": 2,
    "alarm_email": "",
    "agentcore_runtime_arn": "",
    "agentcore_qualifier": ""
  }
}
